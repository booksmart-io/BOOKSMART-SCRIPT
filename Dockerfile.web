FROM node:22-bookworm-slim AS build

WORKDIR /app
RUN corepack enable

ENV PORT=5173
ENV BASE_PATH=/

COPY . .

RUN pnpm install --frozen-lockfile
RUN pnpm --filter @workspace/booksmart build

FROM nginx:1.27-alpine AS runtime

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/artifacts/booksmart/dist/public /usr/share/nginx/html

EXPOSE 80
